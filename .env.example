# -------------------------------------------------------------
# INELEG-APP - Variáveis de Ambiente (Guia completo)
# Objetivo: servir de checklist único para Vercel + Cloudflare (padrão Hub)
# Copie para .env.local e preencha com valores reais.
# Nunca commite credenciais reais no repositório.
# -------------------------------------------------------------

# =============================================================
# 1) APP / VERCEL (runtime Next.js)
# =============================================================

# Ambiente da aplicação (development, production, test)
NODE_ENV=development

# Supabase (frontend + backend)
# URL do projeto Supabase usada pelo cliente.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Chave pública (anon) usada pelo cliente. Não deve ser privilegiada.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Chave com permissões de Service Role. Necessária para rotas API e webhooks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct connection to the database. Used for migrations
SUPABASE_DB_URL=postgresql://postgres.btdbfspuazgerdbmurza:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Keepalive receptor (Supabase Edge Function)
# IMPORTANTE: deve ser exatamente o mesmo token usado no Worker Master keepvasne.
# Segredo para o sistema de heartbeat (Hub Keepalive Pattern).
KEEPALIVE_TOKEN=defina_um_segredo_forte
# Para status + events
KEEPALIVE_EVENTS_ENABLED=true
# Metadados opcionais do receptor
KEEPALIVE_PROJECT_SLUG=inelegis
KEEPALIVE_ENVIRONMENT=prod
KEEPALIVE_REGION=sa-east-1
KEEPALIVE_SOURCE=cloudflare

# =============================================================
# 2) APP / LOCAL (scripts utilitários e UI) - ESSENCIAIS
# =============================================================

# Zeladoria (manutenção e limpeza)
# Token para proteger endpoints de manutenção (Faxina automática do histórico).
CRON_SECRET=your-cron-secret
# Dias de retenção para o histórico de consultas (Ex: 90 dias).
HISTORY_RETENTION_DAYS=90

# =============================================================
# 4) Governança Hub (opcional local / obrigatório no CI)
# =============================================================
# Token de acesso (GitHub GHP) para o satélite ler as regras e scripts do Hub Central.
HUB_ACCESS_TOKEN=your-hub-token

# Dashboard Admin
# Token Bearer para autenticação em /api/dashboard (painel administrativo).
ANALYTICS_ADMIN_TOKEN=your-analytics-admin-token
