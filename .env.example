# -------------------------------------------------------------
# INELEG-APP - Variáveis de Ambiente (EXEMPLO)
# Escopo: gerado a partir do `.env.local` canônico (sem valores reais).
# Uso: copie para `.env.local` e preencha os valores reais.
# Referências: `README.md`
# -------------------------------------------------------------

# =============================================================
# 1) APP / NEXT.JS / VERCEL - OBRIGATÓRIAS
# =============================================================

NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NODE_ENV=production
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================
# 2) BANCO / SUPABASE
# =============================================================

SUPABASE_DB_URL=

# =============================================================
# 3) KEEPALIVE RECEPTOR (/api/keepalive)
# =============================================================

KEEPALIVE_ENVIRONMENT=prod
KEEPALIVE_EVENTS_ENABLED=true
KEEPALIVE_PROJECT_SLUG=ineleg
KEEPALIVE_REGION=sa-east-1
KEEPALIVE_SOURCE=cloudflare
KEEPALIVE_TOKEN=

# =============================================================
# 4) CLOUDFLARE WORKER MASTER (frota keepalive)
# =============================================================

# (não configurado neste projeto)

# =============================================================
# 5) ZELADORIA (manutenção / cron)
# =============================================================

CRON_SECRET=
HISTORY_RETENTION_DAYS=

# =============================================================
# 6) GOVERNANÇA / CI / SCRIPTS
# =============================================================

HUB_ACCESS_TOKEN=

# =============================================================
# 7) INELEG-APP — ESPECÍFICO DO PROJETO
# =============================================================

ANALYTICS_ADMIN_TOKEN=

# =============================================================
# 8) OBSERVABILIDADE / OPCIONAIS
# =============================================================

# (não configurado neste projeto)
